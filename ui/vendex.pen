    {
      "type": "note",
      "id": "ey5gS",
      "x": 577,
      "y": 2000,
      "name": "n1",
      "width": 300,
      "height": 80,
      "content": "Buy List Manager — Vendors manage cards they want to acquire. Mirrors the Inventory Manager layout. Status badges show which wants have been matched to other vendors' inventory at the current event."
    },
    {
      "type": "note",
      "id": "RAocV",
      "x": 3537,
      "y": 2000,
      "name": "n3",
      "width": 300,
      "height": 80,
      "content": "Attendee Listings (Vendor View) — Vendors browse anonymous card postings from convention attendees. Can filter by buy list matches. Make offers on cards; identities stay hidden until the attendee accepts."
    },
    {
      "type": "note",
      "id": "bpRQT",
      "x": 5017,
      "y": 2000,
      "name": "n4",
      "width": 300,
      "height": 80,
      "content": "Offers Dashboard — Central hub for all vendor offer activity. Tracks pending, accepted, and declined offers across both vendor overlaps and attendee listings. Color-coded prices show favorable vs. below-ask offers."
    },
    {
      "type": "note",
      "id": "kQffk",
      "x": 2219,
      "y": 2000,
      "name": "n2",
      "width": 300,
      "height": 80,
      "content": "Events Hub — Browse, discover, and register for upcoming Pokemon TCG conventions. Each card shows vendor count, cards listed, and overlap stats. Three states: registered, register CTA, and coming soon."
    }
